{
  "name": "n8n-nodes-teckel-ipfs",
  "version": "1.0.2",
  "description": "Store, retrieve and pin encrypted files on IPFS via the teckel platform.",
  "keywords": [
    "n8n-community-node-package",
    "ipfs",
    "decentralized-storage",
    "encryption",
    "pinning",
    "file-storage",
    "web3",
    "content-addressing"
  ],
  "license": "MIT",
  "author": "teckel-io",
  "homepage": "https://github.com/teckel-io/n8n-nodes/tree/main/n8n-nodes-teckel-ipfs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teckel-io/n8n-nodes.git",
    "directory": "n8n-nodes-teckel-ipfs"
  },
  "bugs": {
    "url": "https://github.com/teckel-io/n8n-nodes/issues"
  },
  "main": "index.js",
  "files": [
    "index.js",
    "dist/"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "dev": "tsc --watch"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/TeckelIpfsApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/TeckelIpfs/TeckelIpfs.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "n8n-workflow": {
      "optional": true
    }
  }
}
